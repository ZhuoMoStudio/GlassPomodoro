<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 麦克风权限（声波动效检测用） -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- 前台服务权限（Android 13+ 通知） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 查询正在播放的媒体应用（Android 11+ 需要） -->
    <queries>
        <intent>
            <action android:name="android.media.action.MEDIA_PLAY_FROM_SEARCH" />
        </intent>
        <package android:name="com.spotify.music" />
        <package android:name="com.apple.android.music" />
        <package android:name="com.netease.cloudmusic" />
        <package android:name="com.tencent.qqmusic" />
        <package android:name="com.sina.weibo" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GlassPomodoro"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.GlassPomodoro">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
